					"when": "false"
				},
				{
					"command": "tia-import.compareS7dclRevisionsInAct",
					"when": "false"
				}
			],
			"explorer/context": [
				{
					"command": "tia-import.previewBlockWithAutomationCompare",
					"when": "resourceExtname == .xml",
					"group": "tiaPortalPreview@1"
				},
				{
					"command": "tia-import.previewS7dclLadFbd",
					"when": "resourceExtname == .s7dcl",
					"group": "tiaPortalPreview@1"
				},
				{
					"command": "tia-import.compareS7dclRevisionsInAct",
					"when": "resourceExtname == .s7dcl || resourceExtname == .xml",
					"group": "tiaPortalPreview@2"
				},
				{
					"command": "tia-import.exportBlockToTia",
					"when": "resourceExtname == .xml && resourcePath =~ /.*Program.*blocks.*/i",
					"group": "tiaPortal@1"
