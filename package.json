		"configuration": {
			"title": "TIA Portal Import",
			"properties": {
				"tiaImport.tiaPortalVersion": {
					"type": "integer",
					"default": 21,
					"enum": [
						18,
						19,
						20,
						21
					],
					"enumDescriptions": [
						"TIA Portal V18",
						"TIA Portal V19",
						"TIA Portal V20",
						"TIA Portal V21"
					],
					"description": "TIA Portal version to use for Openness API. Changing this requires reloading the extension."
				},
				"tiaImport.exportFolderName": {
					"type": "string",
					"default": "TiaExport",
					"description": "Name of the folder in workspace where TIA Portal data will be stored"
				},
				"tiaImport.tiaPortalPath": {
					"type": "string",
					"default": "",
					"description": "Path to TIA Portal installation directory. Leave empty to auto-detect based on selected version (C:\\Program Files\\Siemens\\Automation\\Portal V<version>)."
				},
				"tiaImport.autoConnect": {
					"type": "boolean",
					"default": false,
					"description": "Automatically connect to TIA Portal on extension activation"
				},
				"tiaImport.includeComments": {
					"type": "boolean",
					"default": true,
					"description": "Include comments when exporting blocks"
				},
				"tiaImport.exportFormat": {
					"type": "string",
					"default": "sd",
					"enum": [
						"xml",
						"sd"
					],
					"enumDescriptions": [
						"SimaticML XML format - standard TIA Portal export format",
						"SIMATIC Source Documents - auto-selects format by language: SCL blocks → .scl, LAD/FBD blocks → .s7dcl/.s7res"
					],
					"description": "Default export format for program blocks"
				},
				"tiaImport.dbExportFormat": {
					"type": "string",
					"default": "db",
					"enum": [
						"xml",
						"db"
					],
					"enumDescriptions": [
						"SimaticML XML format - standard TIA Portal export (default)",
						"Source file (.db) - text-based DATA_BLOCK source via GenerateSource API"
					],
					"description": "Export format for Global Data Blocks (Instance DBs always use XML)"
				},
				"tiaImport.tagTableFormat": {
					"type": "string",
					"default": "xlsx",
					"enum": [
						"xml",
						"xlsx"
					],
					"enumDescriptions": [
						"SimaticML XML format (default)",
						"XLSX spreadsheet format (converts from XML after export)"
					],
					"description": "Export format for PLC tag tables"
				},
				"tiaImport.hwConfigFormat": {
					"type": "string",
					"default": "cax",
					"enum": [
						"xml",
						"cax"
					],
					"enumDescriptions": [
						"Custom HW Config XML produced by the wrapper (default; per-device folders)",
						"AutomationML / CAx (.aml) via TIA Openness CaxProvider"
					],
					"description": "File format used for hardware configuration import (TIA → workspace) and export (workspace → TIA)"
				},
				"tiaImport.showImportExportDetails": {
					"type": "boolean",
					"default": false,
					"description": "Show detailed import/export messages plus wrapper and TIA Openness warnings/errors in the output log"
				},
				"tiaImport.preserveTimestamps": {
					"type": "boolean",
					"default": true,
					"description": "Preserve original timestamps in exported files"
				},
				"tiaImport.excludeSystemBlocks": {
					"type": "boolean",
					"default": true,
					"description": "Exclude system blocks from export"
				},
				"tiaImport.dotnetPath": {
					"type": "string",
					"default": "",
					"description": "Path to .NET runtime (leave empty for auto-detect)"
				},
				"tiaImport.importProgress.itemsPerSecond": {
					"type": "number",
					"default": 1,
					"minimum": 0.1,
					"maximum": 100,
					"description": "Speed multiplier for time-based import progress. 1.0 uses built-in artifact weights calibrated by block/export type (SD, SCL/DB source, XML, ACT XML preview, UDT, tag/watch table) and HW Config device imports, plus a 10% safety buffer; increase if your TIA exports faster, decrease if slower."
				},
				"tiaImport.s7dclPreviewXml.enabled": {
					"type": "boolean",
					"default": true,
					"description": "When importing blocks from TIA Portal in SD format (.s7dcl/.s7res), additionally write a SimaticML XML mirror under <workspace>/.tiaPreview/ so that the right-click 'TIA Import: LAD/FBD Preview' command can render the block graphically in SIMATIC Automation Compare Tool without re-exporting from TIA Portal."
				},
				"tiaImport.automationCompareTool.path": {
					"type": "string",
					"default": "",
					"description": "Path to the SIMATIC Automation Compare Tool executable. Leave empty to auto-detect from common Siemens installation folders and registry entries."
				},
				"tiaImport.automationCompareTool.autoDetect": {
					"type": "boolean",
					"default": true,
					"description": "Automatically search for SIMATIC Automation Compare Tool when no explicit executable path is configured."
				},
				"tiaImport.automationCompareTool.argumentsTemplate": {
					"type": "string",
					"default": "${file}",
					"description": "Argument template used when external mode launches SIMATIC Automation Compare Tool. Use ${file} for the fully-qualified file path and ${title} for the status-bar title, for example: --uiCulture=en-US --title1 \"${title}\" \"${file}\"."
				},
				"tiaImport.automationCompareTool.compareArgumentsTemplate": {
					"type": "string",
					"default": "\"${file1}\" \"${file2}\" --title1 \"${title1}\" --title2 \"${title2}\"",
					"description": "Argument template used when comparing two SimaticML XML files (e.g. two Git revisions) in SIMATIC Automation Compare Tool. Tokens: ${file1}, ${file2}, ${title1}, ${title2}."
				},
				"tiaImport.automationCompareTool.embedMode": {
					"type": "string",
					"default": "native",
					"enum": [
						"external",
						"native"
					],
					"enumDescriptions": [
						"Open ACT in its own native window (stable fallback).",
						"Open ACT's installed renderer inside a VS Code webview panel. Falls back to the external ACT window if the renderer files cannot be located."
					],
					"description": "How to show SIMATIC Automation Compare Tool previews. Native mode loads ACT's installed renderer in a VS Code webview panel; external mode launches ACT in its own window."
				},
				"tiaImport.automationCompareTool.embedTimeoutMs": {
					"type": "integer",
					"default": 10000,
					"minimum": 1000,
					"maximum": 60000,
					"description": "Reserved timeout for future ACT native-window fallback behavior. The default VS Code webview preview does not use this value."
				},
				"tiaImport.compileAfterExport": {
					"type": "string",
					"default": "ask",
					"enum": [
						"always",
						"ask",
						"never"
					],
					"enumDescriptions": [
						"Always compile PLC software after exporting blocks or program",
						"Ask whether to compile after each export (default)",
						"Never compile after export"
					],
					"description": "Whether to compile PLC software in TIA Portal after exporting blocks or program (does not apply to HW config export)"
				},
				"tiaImport.autoExportCrossReferences": {
					"type": "string",
					"enum": [
						"always",
						"ask",
						"never"
					],
					"default": "ask",
					"enumDescriptions": [
						"Always dump cross-references after every device/project import (no prompt)",
						"Ask per PLC when the dump is about to start; auto-skips after 5s if you don't respond (default)",
						"Never dump cross-references automatically"
					],
					"description": "Whether to dump the cross-reference table (cross-references.jsonl + CSV) into <Device>/CrossReferences/ after a device or project import. Requires TIA Portal V18+. ⚠️ Generating cross-references is performed by TIA Portal itself and can take several minutes — 10 min+ on large PLCs (thousands of blocks / fault-tolerant projects)."
				},
				"tiaImport.lmTools.autoConfirmImports": {
					"type": "boolean",
					"default": false,
					"description": "When enabled, the Copilot tia_import_* tools no longer ask for confirmation before overwriting objects in TIA Portal."
				},
				"tiaImport.lmTools.maxFixIterations": {
					"type": "integer",
					"default": 5,
					"minimum": 1,
					"maximum": 20,
					"description": "Maximum number of import → compile → fix iterations the tia_fix_compile_errors Copilot tool will run before giving up."
				},
				"tiaImport.cli.enabled": {
					"type": "boolean",
					"default": false,
					"description": "Start the localhost-only JSON CLI bridge and write .tia/cli.json for external automation scripts. Disabled by default — enable only when you need to drive the extension from external scripts (PowerShell, Python, Node)."
				}
			}
		}
