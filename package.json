		"onLanguageModelTool:tia_disconnect",
		"onLanguageModelTool:tia_list_projects",
		"onLanguageModelTool:tia_select_project",
		"onLanguageModelTool:tia_list_devices",
		"onLanguageModelTool:tia_list_blocks",
		"onLanguageModelTool:tia_export_block",
		"onLanguageModelTool:tia_export_device",
		"onLanguageModelTool:tia_export_hw_config",
		"onLanguageModelTool:tia_import_file",
		"onLanguageModelTool:tia_import_folder",
		"onLanguageModelTool:tia_import_hw_config",
		"onLanguageModelTool:tia_export_project",
		"onLanguageModelTool:tia_refresh",
		"onLanguageModelTool:tia_compile",
		"onLanguageModelTool:tia_get_problems",
		"onLanguageModelTool:tia_fix_compile_errors",
		"onLanguageModelTool:tia_export_cross_references",
		"onChatParticipant:tia.assistant"
