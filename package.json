				},
				{
					"command": "tia-import.exportBlockToTia",
					"when": "resourceExtname == .db",
					"group": "tiaPortal@1"
				},
				{
					"command": "tia-import.exportBlockFolderToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*Program.*blocks.*/i",
					"group": "tiaPortal@2"
				},
				{
					"command": "tia-import.exportXmlToTia",
					"when": "resourceExtname == .xml && !(resourcePath =~ /.*Program.*blocks.*/i) && !(resourcePath =~ /.*[/\\\\]IO_Devices([/\\\\].*)?$/)",
					"group": "tiaPortal@3"
				},
				{
					"command": "tia-import.exportXmlFolderToTia",
					"when": "explorerResourceIsFolder && !(resourcePath =~ /.*Program.*blocks.*/i) && !(resourcePath =~ /.*[/\\\\]IO_Devices([/\\\\].*)?$/)",
					"group": "tiaPortal@4"
				},
				{
					"command": "tia-import.exportXlsxToTia",
					"when": "resourceExtname == .xlsx && resourcePath =~ /.*PLC.*tags.*/i",
					"group": "tiaPortal@5"
				},
				{
					"command": "tia-import.exportXlsxFolderToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*PLC.*tags.*/i",
					"group": "tiaPortal@6"
				},
				{
					"command": "tia-import.exportHwConfigToTia",
					"when": "resourceExtname == .xml && resourcePath =~ /.*HwConfig.*|.*DeviceConfiguration.*|.*Devices.*/",
					"group": "tiaPortalHw@1"
				},
				{
					"command": "tia-import.exportHwConfigToTia",
					"when": "resourceExtname == .aml",
					"group": "tiaPortalHw@1"
				},
				{
					"command": "tia-import.exportHwConfigFolderToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*DeviceConfiguration.*/",
					"group": "tiaPortalHw@2"
				},
				{
					"command": "tia-import.exportHwConfigFolderToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*[/\\\\]IO_Devices$/",
					"group": "tiaPortalHw@2"
				},
				{
					"command": "tia-import.exportHwConfigFolderToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*Devices[/\\\\](PLCs|HMIs|IO_Devices|Computers)[/\\\\][^/\\\\]+$/",
					"group": "tiaPortalHw@2"
				},
				{
					"command": "tia-import.exportUnifiedToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*Devices[/\\\\](PLCs|HMIs|IO_Devices|Computers)[/\\\\][^/\\\\]+$/",
					"group": "tiaPortal@0"
				},
				{
					"command": "tia-import.exportProgramToTia",
					"when": "explorerResourceIsFolder && resourcePath =~ /.*Devices[/\\\\](PLCs|HMIs|IO_Devices|Computers)[/\\\\][^/\\\\]+$/",
					"group": "tiaPortal@1"
				}
			]
		},
