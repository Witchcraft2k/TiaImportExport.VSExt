{
	"name": "tia-import",
	"displayName": "TIA Portal Import",
	"description": "Import/export PLC programs from/to Siemens TIA Portal using TIA Portal Openness API",
	"version": "3.0.12",
	"license": "MIT",
	"publisher": "MariuszCzyrnek",
	"author": "Mariusz Czyrnek",
	"icon": "resources/icons/extension-icon.png",
	"engines": {
		"vscode": "^1.95.0"
	},
	"categories": [
		"Other"
	],
	"keywords": [
		"siemens",
		"tia portal",
		"tiaportal",
		"tia-portal",
		"plc",
		"openness",
		"automation",
		"siemens AI",
		"tia portal AI",
		"tiaportal AI",
		"tia-portal AI",
		"plc AI",
		"openness AI",
		"automation AI",
		"tia portal copilot",
		"tiaportal copilot",
		"tia-portal copilot",
		"plc copilot",
		"openness copilot",
		"automation copilot"
	],
	"activationEvents": [
		"onStartupFinished",
		"onCommand:tia-import.startCli",
